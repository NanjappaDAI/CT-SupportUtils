<configuration>

  <!-- Console Appender -->
  <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>
        [%d{HH:mm:ss.SSS}] [%X{testId:-NA}] [device=%X{device:-NA}] %-5level - %msg%n
      </pattern>
    </encoder>
  </appender>

  <!-- Root Logger -->
  <root level="INFO">
    <appender-ref ref="CONSOLE"/>
  </root>

</configuration>